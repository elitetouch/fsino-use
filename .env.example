# Backend API HOST ROOT — the code internally prepends /api/v1, so
# set this to the host only (matches the super-admin portal convention).
#   Local dev: NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
#   Production: NEXT_PUBLIC_API_BASE_URL=https://api.fsinnovation.net
NEXT_PUBLIC_API_BASE_URL=https://api.fsinnovation.net

# Optional: app name shown in tab title + footer.
NEXT_PUBLIC_APP_NAME=Farm Support Innovation

# Google Play Store URL for the FarmSpeak Android app — used by the
# "Get it on Google Play" buttons on the landing page. Replace with the
# real listing URL once published.
NEXT_PUBLIC_PLAY_STORE_URL=https://play.google.com/store/apps/details?id=com.farmspeak.app
